{
  "name": "hrms",
  "version": "0.1.0",
  "description": "Kenyan HRMS — modular monolith (NestJS + Prisma + PostgreSQL)",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev -w @hrms/api",
    "api:build": "npm run build -w @hrms/api",
    "api:migrate": "npm run prisma:migrate -w @hrms/api",
    "verify:spine": "cd apps/api && npx ts-node scripts/verify-spine.ts",
    "bundle:cpanel": "bash apps/api/scripts/build-cpanel-bundle.sh",
    "db:up": "docker compose up -d db",
    "up": "docker compose up --build"
  },
  "dependencies": {}
}
