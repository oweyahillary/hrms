# ---- Runtime ----
NODE_ENV=development
PORT=3000

# ---- Database ----
# In docker-compose the host is the service name "db"; locally it's localhost.
DATABASE_URL="postgresql://hrms:hrms@localhost:5432/hrms?schema=public"

# ---- App-layer crypto (REQUIRED — the app refuses to boot without these) ----
# Which provider encrypts NEW writes: "env" or "aws_kms".
# The env master key is always required regardless, so that values written
# under env can still be decrypted after a later switch to KMS.
KEY_PROVIDER=env

# 32-byte keys, base64-encoded. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
HMAC_KEY=

# ---- KMS (only needed when KEY_PROVIDER=aws_kms) ----
# AWS_REGION=af-south-1
# AWS_KMS_KEY_ID=arn:aws:kms:af-south-1:...:key/....
# Credentials come from the standard AWS chain (instance role / env / profile).

# ---- Dev-only request context (optional) ----
# Pre-auth, the request context has no authenticated user. These let the
# tenant-scoping + audit spine work during local development by prefilling the
# org/user. Server-controlled only — NEVER trust client input for these.
# Once auth is built, the auth guard populates the context instead.
# DEV_ORG_ID=
# DEV_USER_ID=

# ---- Auth (JWT + refresh) — REQUIRED ----
# Two DISTINCT secrets (>=16 chars). Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Optional (defaults shown):
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL_DAYS=7

# ---- Seed defaults (optional; used by `npm run seed`) ----
# SEED_ORG_NAME=Demo Organization
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=ChangeMe123!

# ---- File storage (employee documents) ----
# Base directory for uploaded files. Point at a mounted volume (Docker/VPS) or a
# directory OUTSIDE the web root (cPanel). Defaults to ./storage.
# STORAGE_DIR=./storage
