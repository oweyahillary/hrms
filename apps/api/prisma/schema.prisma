  RECEIVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum BreachStatus {
  OPEN
  CONTAINED
  CLOSED
}

enum ExitReason {
  RESIGNATION
  TERMINATION
  REDUNDANCY
  RETIREMENT
}

/// How a monthly basic salary is converted into a day's pay for severance (§40)
/// and notice pay-in-lieu (§35). The Employment Act fixes severance at "fifteen
/// days' pay for each completed year" but never defines a day's pay from a
/// monthly wage: CALENDAR_30 (÷30 calendar days — the common convention, giving
/// the widely-cited "half a month per completed year") vs WORKING_26 (÷26
/// working days). Default CALENDAR_30. See docs/severance.md for the tradeoff.
enum SeveranceDayRateBasis {
  CALENDAR_30 // a day's pay = monthly basic / 30 (calendar days)
  WORKING_26 // a day's pay = monthly basic / 26 (working days)
}

// ----------------------------------------------------------------------------
// Organization & Access
// ----------------------------------------------------------------------------

/// Tenant anchor. Every other table's organizationId references this.
/// Who signs off leave. Multi-level runs department head -> HR in that order.
enum LeaveApprovalMode {
  DEPT_HEAD_THEN_HR // two steps: the employee's department head, then HR
  HR_ONLY // one step: HR
  DEPT_HEAD_ONLY // one step: the employee's department head
}

model Organization {
  id              String   @id @default(uuid())
  name            String
  kraPin          String? // employer's own PIN — needed in cleartext for filings, not encrypted
  physicalAddress String?
  // Branding for payslips and other generated documents.
  registrationNumber String?
  payslipNotice      String? // optional statutory/custom line shown on payslips
  logoPath           String? // stored relative path to the org logo (PNG/JPEG)
  logoAlignment      LogoAlignment @default(LEFT)
  brandColor         String? // hex (e.g. "#0c6355") — drives the web app's accent theme
  // Employer payment config for bank EFT/RTGS bulk files (the debit account
  // salaries are paid from; purpose code is bank-assigned). Own-company data,
  // not employee PII, so stored plaintext like the employer's own KRA PIN.
  bankAccountNumber  String?
  bankPurposeCode    String?
  // Leave approval policy. Approvers are DERIVED from these, not chosen by the
  // applicant — letting someone pick who signs off their own leave is a control
  // weakness, not a convenience. allowEmployeeChosenApprovers is the explicit
  // opt-out for organisations that want the old behaviour.
  leaveApprovalMode            LeaveApprovalMode @default(DEPT_HEAD_THEN_HR)
  /// The specific HR user who signs off. "HR" is a role; an approval step needs
  /// a person. Plain column for the same reason as Department.headEmployeeId —
  /// Organization already relates to User via `users`. Validated in the service.
  leaveHrApproverUserId        String?
  allowEmployeeChosenApprovers Boolean           @default(false)

  // Employee number auto-numbering, e.g. prefix "VIVO" + padding 4 -> VIVO0001.
  // A null prefix means auto-numbering is OFF and the caller must supply the
  // number itself — that's the default, so existing behaviour is unchanged.
  employeeNumberPrefix  String? // e.g. "VIVO", "RCLFIN", "EMP-"
  employeeNumberPadding Int     @default(4) // zero-pad width of the counter
  employeeNumberNextSeq Int     @default(1) // next counter value to hand out

  // Severance & notice pay-in-lieu day-rate basis (÷30 calendar vs ÷26 working).
  // See the SeveranceDayRateBasis enum and docs/severance.md. The value in force
  // is snapshotted into each severance calculation's breakdown, so editing this
  // later never retroactively changes an already-persisted calculation.
  severanceDayRateBasis SeveranceDayRateBasis @default(CALENDAR_30)

  /// Minutes of grace after a shift's scheduled start before a clock-in is
  /// LATE rather than PRESENT — see attendance/derive-status.ts.
  lateGraceMinutes Int @default(15)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt // [T2]

  users                 User[]
  departments           Department[]
  jobTitles             JobTitle[]
  employees             Employee[]
  employeeDocuments     EmployeeDocument[]
  attendanceRecords     AttendanceRecord[]
  auditLogs             AuditLog[]
  publicHolidays        PublicHoliday[]
  leaveTypes            LeaveType[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]
  shiftDefinitions      ShiftDefinition[]
  shiftAssignments      ShiftAssignment[]
  salaryStructures      SalaryStructure[]
  retentionPolicies     RetentionPolicy[]
  breachIncidents       BreachIncident[]
  payrollRuns           PayrollRun[]
  consentRecords        ConsentRecord[]
  dataSubjectRequests   DataSubjectRequest[]
  severanceCalculations SeveranceCalculation[]
  roles                 Role[]
  loans                 Loan[]
  payrollAdjustments    PayrollAdjustment[]

  @@map("organizations")
}

/// Login identity. Distinct from Employee — admins/HR staff may not be
/// employees of the org they administer.
model User {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  passwordHash   String
  mustChangePassword Boolean @default(false) // force rotation on next login (seeded admin / admin-forced reset)
  roleId         String
  employeeId     String?   @unique
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String? // [T1-4] TOTP secret (encrypted at app layer); null until MFA enrolled
  mfaBackupCodes String[]  @default([]) // [T1-4] hashed one-time recovery codes
  lastLoginAt    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt // [T2]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  auditLogs            AuditLog[]
  uploadedDocuments    EmployeeDocument[]
  approvalSteps        LeaveApprovalStep[]
  createdPayrollRuns   PayrollRun[]
  generatedBankBatches BankExportBatch[]
  calculatedSeverances SeveranceCalculation[]
  sessions             Session[] // [T1-4]
  createdLoans         Loan[]
  createdAdjustments   PayrollAdjustment[]
  approvedSalaryRevisions SalaryStructure[] @relation("SalaryRevisionApprover")

  // DECISION: email scoped-unique per org, NOT globally unique. Keeps the
  // "multi-tenant is a config flip" promise honest — two tenants could
  // legitimately use the same email as separate logins. Override to a global
  // @unique if you want one-email-one-login forever.
  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

/// [T1-4] Refresh-token / session store. Without this there is no way to
/// revoke a session or implement real logout. DB table (not Redis) keeps the
/// client's self-hostable Compose stack to two services.
model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique // store a hash, never the raw token
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// permissions kept as JSONB for Phase 1 flexibility.
/// Default seed roles: Admin, HR Officer, Manager, Employee.
model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  permissions    Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt // [T2]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  users        User[]

  @@unique([organizationId, name]) // [T2] no two "Admin" roles in one org
  @@index([organizationId])
  @@map("roles")
}

/// Append-only. Written by a shared interceptor across every module.
/// [T1-5] userId is nullable + SetNull so anonymising/removing a user never
/// destroys the audit trail — the log survives, it just loses the actor link.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String
  beforeState    Json?
  afterState     Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([organizationId, createdAt]) // [T2] powers "recent activity in this org"
  @@map("audit_logs")
  // NOTE: revoke UPDATE/DELETE on this table from the app DB role in a manual
  // migration — application-level "append only" is not a real control.
}

// ----------------------------------------------------------------------------
// Employees
// ----------------------------------------------------------------------------

model Department {
  id                 String   @id @default(uuid())
  organizationId     String
  name               String
  parentDepartmentId String?
  /// The employee who heads this department. They approve their team's leave.
  /// Deliberately a plain column, not a relation: Department already relates to
  /// Employee via `employees`, and a second relation between the same two models
  /// would force BOTH to be explicitly named — renaming a live FK constraint for
  /// a pointer. Existence is validated in the service instead.
  headEmployeeId     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt // [T2]

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parentDepartment Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Restrict)
  subDepartments   Department[] @relation("DepartmentHierarchy")
  employees        Employee[]

  @@index([organizationId])
  @@index([parentDepartmentId]) // [T2] walk the org hierarchy without a scan
  @@index([headEmployeeId])
  @@map("departments")
}

model JobTitle {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  grade          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt // [T2]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employees    Employee[]

  @@index([organizationId])
  @@map("job_titles")
}

/// employmentType directly drives NSSF/statutory eligibility — always explicit.
///
/// [T1-1] Sensitive identifiers (nationalId, kraPin, bankAccountNumber) are
/// stored as app-layer ciphertext. Because you cannot index/search ciphertext,
/// each searchable identifier gets a companion deterministic HMAC column that
/// IS indexed and searched on (blind index). bankAccountNumber is encrypted but
/// not searchable, so it needs no HMAC.
///
/// DECISION: no deletedAt / soft-delete. A DPA erasure is an anonymise-in-place
/// workflow (scrub PII fields, keep the row) so payslips/audit stay
/// referentially intact through their 5–7yr retention. Soft-delete would leave
/// the PII sitting in the row, which defeats the erasure.
model Employee {
  id                String           @id @default(uuid())
  organizationId    String
  employeeNumber    String
  firstName         String
  lastName          String
  nationalId        String // [T1-1] ciphertext
  nationalIdHmac    String // [T1-1] blind index for lookup
  kraPin            String? // [T1-1] ciphertext
  kraPinHmac        String? // [T1-1] blind index for lookup
  phone             String?
  email             String?
  dateOfBirth       DateTime?        @db.Date // [T1-2]
  gender            String?
  departmentId      String?
  jobTitleId        String?
  employmentType    EmploymentType
  employmentStatus  EmploymentStatus @default(ACTIVE)
  hireDate          DateTime         @db.Date // [T1-2]
  exitDate          DateTime?        @db.Date // [T1-2]
  bankName          String?
  bankAccountNumber String? // [T1-1] ciphertext, not searchable → no HMAC
  bankCode          String? // beneficiary bank code (public identifier, not sensitive)
  bankBranchCode    String? // branch code for interbank/PesaLink files
  nextOfKin         Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitle     JobTitle?    @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)

  user                  User?
  documents             EmployeeDocument[]
  attendanceRecords     AttendanceRecord[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]
  shiftAssignments      ShiftAssignment[]
  salaryStructures      SalaryStructure[]
  payslips              Payslip[]
  consentRecords        ConsentRecord[]
  dataSubjectRequests   DataSubjectRequest[]
  severanceCalculations SeveranceCalculation[]
  loans                 Loan[]
  payrollAdjustments    PayrollAdjustment[]

  @@unique([organizationId, employeeNumber])
  @@index([nationalIdHmac]) // [T1-1] was nationalId
  @@index([kraPinHmac]) // [T1-1] was kraPin
  @@index([departmentId])
  @@index([jobTitleId]) // [T2] headcount-by-title reporting
  @@index([employmentStatus])
  @@map("employees")
}

/// isSensitive flags DPA "sensitive personal data" documents for stricter
/// access logging. [T1-5] employee docs are retained — never cascade-delete.
model EmployeeDocument {
  id             String       @id @default(uuid())
  organizationId String
  employeeId     String
  documentType   DocumentType
  filePath       String
  uploadedById   String
  uploadedAt     DateTime     @default(now())
  isSensitive    Boolean      @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId])
  @@map("employee_documents")
}

// ----------------------------------------------------------------------------
// Attendance & Leave
// ----------------------------------------------------------------------------
// Biometric note: AttendanceSource.BIOMETRIC is already supported. Phase 1
// populates it via a CSV/Excel importer (from the device's own export). A live
// ZK (ADMS push) / Hikvision (ISAPI event) ingest adapter + a devices registry
// + a device_enrollments map get added in Phase 2 — no change to this table.

model PublicHoliday {
  id             String   @id @default(uuid())
  organizationId String
  date           DateTime @db.Date // [T1-2] a calendar day, not an instant
  name           String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([date])
  @@map("public_holidays")
}

/// Composite index (employeeId, date) covers the most common query.
model AttendanceRecord {
  id             String           @id @default(uuid())
  organizationId String
  employeeId     String
  date           DateTime         @db.Date // [T1-2]
  clockIn        DateTime? // instant — keep full timestamp
  clockOut       DateTime? // instant — keep full timestamp
  status         AttendanceStatus
  source         AttendanceSource @default(MANUAL)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId, date])
  @@map("attendance_records")
}

enum ShiftAssignmentSource {
  MANUAL
  IMPORT
}

/// Org-configurable shift patterns — never hardcoded (same philosophy as
/// StatutoryRate: data, not code). Seeded with Kenyan-default shifts on org
/// provisioning (scripts/seed.ts); HR can add/edit/deactivate from there.
/// startTime/endTime are "HH:MM" time-of-day strings, not DateTimes — a
/// shift definition is a repeating daily pattern with no calendar date of
/// its own. crossesMidnight and isNightShift are independent flags (a shift
/// can cross midnight without being labelled the night shift), though in
/// the seeded defaults only Night sets both.
model ShiftDefinition {
  id              String   @id @default(uuid())
  organizationId  String
  code            String // short, e.g. "M", "A", "N", "G" — unique per org
  name            String
  startTime       String
  endTime         String
  crossesMidnight Boolean  @default(false)
  isNightShift    Boolean  @default(false)
  breakMinutes    Int      @default(0)
  active          Boolean  @default(true)

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignments  ShiftAssignment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("shift_definitions")
}

/// One shift per employee per day — application-level upsert on
/// (employeeId, date) conflict, same pattern as AttendanceRecord. A shift
/// with crossesMidnight=true belongs to the date it STARTS, never the date
/// it ends on, so a night shift starting the 5th and ending the 6th is one
/// row dated the 5th.
model ShiftAssignment {
  id                String                @id @default(uuid())
  organizationId    String
  employeeId        String
  date              DateTime              @db.Date // [T1-2] the shift's start date
  shiftDefinitionId String
  source            ShiftAssignmentSource @default(MANUAL)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt // [T2]

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  shiftDefinition ShiftDefinition @relation(fields: [shiftDefinitionId], references: [id], onDelete: Restrict)

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([organizationId, date])
  @@map("shift_assignments")
}

enum LeaveAccrualMethod {
  NONE
  UPFRONT
  MONTHLY
  DAILY
}

model LeaveType {
  id               String   @id @default(uuid())
  organizationId   String
  name             String
  isPaid           Boolean  @default(true)
  requiresApproval Boolean  @default(true)
  maxDaysPerYear   Int?

  // Auto-accrual + carry-over policy (carry-over fields are consumed by the
  // year-rollover feature; accrual uses accrualMethod + annualDays).
  accrualMethod         LeaveAccrualMethod @default(NONE)
  annualDays            Int? // annual entitlement the type accrues toward (the per-year cap)
  carryOverMax          Int? // max days carried into next year (0 = none, null = unlimited)
  carryOverExpiryMonths Int? // carried days lapse this many months into the new year (null = never)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt // [T2]

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([organizationId, name]) // [T2]
  @@map("leave_types")
}

model LeaveBalance {
  id              String   @id @default(uuid())
  organizationId  String
  employeeId      String
  leaveTypeId     String
  year            Int
  accruedDays     Decimal  @db.Decimal(5, 2)
  usedDays        Decimal  @default(0) @db.Decimal(5, 2)
  carriedOverDays Decimal  @default(0) @db.Decimal(5, 2) // DECISION: Kenyan annual leave carries over; model it explicitly
  updatedAt       DateTime @updatedAt // [T2]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType    LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, leaveTypeId, year])
  @@index([organizationId])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String             @id @default(uuid())
  organizationId String
  employeeId     String
  leaveTypeId    String
  startDate      DateTime           @db.Date // [T1-2]
  endDate        DateTime           @db.Date // [T1-2]
  daysRequested  Decimal            @db.Decimal(5, 2)
  status         LeaveRequestStatus @default(PENDING)
  reason         String?
  createdAt      DateTime           @default(now())

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee      Employee            @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType     LeaveType           @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approvalSteps LeaveApprovalStep[]

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

/// Row count here is the single/multi-level approval toggle — the approval
/// logic reads this table the same way regardless of how many rows exist.
model LeaveApprovalStep {
  id             String             @id @default(uuid())
  leaveRequestId String
  stepOrder      Int
  approverUserId String
  status         ApprovalStepStatus @default(PENDING)
  actedAt        DateTime?

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade) // [T1-5] steps belong to their request
  approver     User         @relation(fields: [approverUserId], references: [id], onDelete: Restrict)

  @@index([leaveRequestId])
  @@index([approverUserId]) // [T2] powers the "awaiting my approval" inbox
  @@map("leave_approval_steps")
}

// ----------------------------------------------------------------------------
// Payroll
// ----------------------------------------------------------------------------

/// Versioned by effectiveDate/endDate — never overwrite a salary.
model SalaryStructure {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  basicSalary    Decimal   @db.Decimal(12, 2)
  effectiveDate  DateTime  @db.Date // [T1-2]
  endDate        DateTime? @db.Date // [T1-2]
  reason         String // required — why this revision (matches Loan/PayrollAdjustment.reason)
  approvedById   String? // optional — approver, when distinct from whoever entered the revision

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee          @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  approvedBy   User?             @relation("SalaryRevisionApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  components    SalaryComponent[]

  @@index([organizationId])
  @@index([employeeId])
  @@map("salary_structures")
}

model SalaryComponent {
  id                String              @id @default(uuid())
  salaryStructureId String
  componentType     SalaryComponentType
  name              String
  amount            Decimal             @db.Decimal(12, 2)
  isTaxable         Boolean             @default(true)

  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade) // [T1-5] components belong to their structure

  @@index([salaryStructureId])
  @@map("salary_components")
}

/// Keeps the system correct as Kenyan rates change: INSERT a new row with a new
/// effectiveDate; a run uses whichever row was effective on its run date.
/// No organizationId — rates are national. No FK from PayrollRun — by design.
model StatutoryRate {
  id            String            @id @default(uuid())
  rateType      StatutoryRateType
  effectiveDate DateTime          @db.Date // [T1-2]
  parameters    Json // NOTE: validate JSON shape per rateType in the payroll engine (versioned validator)

  @@index([rateType, effectiveDate])
  @@map("statutory_rates")
}

/// [T1-3] Once FINALIZED, immutable in app logic AND enforced by a DB trigger
/// (added in a manual migration). Corrections are a new ADJUSTMENT run linked
/// back via correctsRunId — never an edit to the finalized row.
model PayrollRun {
  id             String           @id @default(uuid())
  organizationId String
  periodMonth    Int
  periodYear     Int
  status         PayrollRunStatus @default(DRAFT)
  runType        PayrollRunType   @default(REGULAR) // [T1-3]
  correctsRunId  String? // [T1-3] set only on ADJUSTMENT runs
  runDate        DateTime         @default(now()) // execution instant — keep full timestamp
  createdById    String
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  correctsRun PayrollRun?  @relation("PayrollAdjustments", fields: [correctsRunId], references: [id], onDelete: Restrict) // [T1-3]
  adjustments PayrollRun[] @relation("PayrollAdjustments")

  payslips          Payslip[]
  bankExportBatches BankExportBatch[]
  loanRepayments      LoanRepayment[]
  payrollAdjustments  PayrollAdjustment[]

  @@index([organizationId, periodYear, periodMonth])
  @@map("payroll_runs")
  // [T1-3] Add via manual migration — one REGULAR run per period, but
  // adjustments may reuse the period (partial unique index):
  //   CREATE UNIQUE INDEX one_regular_run_per_period
  //   ON payroll_runs (organization_id, period_year, period_month)
  //   WHERE run_type = 'REGULAR';
}

/// oneThirdRulePass computed + stored at generation. false blocks finalization.
model Payslip {
  id               String   @id @default(uuid())
  payrollRunId     String
  employeeId       String
  grossPay         Decimal  @db.Decimal(12, 2)
  paye             Decimal  @db.Decimal(12, 2)
  nssfEmployee     Decimal  @db.Decimal(12, 2)
  nssfEmployer     Decimal  @db.Decimal(12, 2)
  shif             Decimal  @db.Decimal(12, 2)
  ahlEmployee      Decimal  @db.Decimal(12, 2)
  ahlEmployer      Decimal  @db.Decimal(12, 2)
  otherDeductions  Decimal  @default(0) @db.Decimal(12, 2)
  netPay           Decimal  @db.Decimal(12, 2)
  oneThirdRulePass Boolean
  pdfPath          String?
  pdfStatus        PayslipPdfStatus @default(PENDING)
  createdAt        DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict) // [T1-5] retained payroll record

  loanRepayments LoanRepayment[]
  adjustments    PayrollAdjustment[]

  @@index([payrollRunId, employeeId])
  @@index([employeeId]) // [T2] payslip history / severance inputs per employee
  @@map("payslips")
}

model BankExportBatch {
  id            String   @id @default(uuid())
  payrollRunId  String
  filePath      String
  format        BankExportFormat
  template      BankExportTemplate @default(GENERIC)
  rowCount      Int      @default(0)
  generatedAt   DateTime @default(now())
  generatedById String

  payrollRun  PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)
  generatedBy User       @relation(fields: [generatedById], references: [id], onDelete: Restrict)

  @@index([payrollRunId]) // [T2]
  @@map("bank_export_batches")
}

// ----------------------------------------------------------------------------
// Compliance
// ----------------------------------------------------------------------------

model ConsentRecord {
  id             String      @id @default(uuid())
  organizationId String
  employeeId     String
  purpose        String
  lawfulBasis    LawfulBasis
  grantedAt      DateTime    @default(now())
  withdrawnAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId])
  @@map("consent_records")
}

/// dueDate = submittedAt + 30 days, set programmatically. Index powers the
/// "overdue requests" alert — the core operational value of this table.
model DataSubjectRequest {
  id             String                   @id @default(uuid())
  organizationId String
  employeeId     String
  requestType    DataSubjectRequestType
  status         DataSubjectRequestStatus @default(RECEIVED)
  submittedAt    DateTime                 @default(now()) // instant
  dueDate        DateTime                 @db.Date // [T1-2] a calendar SLA deadline
  resolvedAt     DateTime? // instant
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId])
  @@index([dueDate])
  @@map("data_subject_requests")
}

model RetentionPolicy {
  id                    String   @id @default(uuid())
  organizationId        String
  recordType            String
  retentionPeriodMonths Int
  legalBasisNote        String?
  updatedAt             DateTime @updatedAt // [T2]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, recordType]) // [T2] one policy per record type
  @@map("retention_policies")
}

/// odpcNotifiedAt vs detectedAt proves 72-hour compliance at a glance — these
/// stay full DateTime (not @db.Date) precisely because the window is to the hour.
model BreachIncident {
  id                    String       @id @default(uuid())
  organizationId        String
  detectedAt            DateTime
  description           String
  affectedEmployeeCount Int
  odpcNotifiedAt        DateTime?
  employeesNotifiedAt   DateTime?
  status                BreachStatus @default(OPEN)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId]) // [T2]
  @@map("breach_incidents")
}

/// calculationBreakdown stores full formula inputs/outputs — critical if a
/// severance amount is ever disputed or audited.
model SeveranceCalculation {
  id                   String     @id @default(uuid())
  organizationId       String
  employeeId           String
  exitDate             DateTime   @db.Date // [T1-2]
  reason               ExitReason
  noticePeriodDays     Int
  severanceAmount      Decimal    @db.Decimal(12, 2)
  calculationBreakdown Json
  calculatedById       String
  createdAt            DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  calculatedBy User         @relation(fields: [calculatedById], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId])
  @@map("severance_calculations")
}

// ----------------------------------------------------------------------------
// Loans, advances & one-off payroll adjustments
// ----------------------------------------------------------------------------

/// Employee salary advances/loans. installmentAmount is computed once at
/// creation ((principal + interest) / numberOfInstallments); balance is
/// decremented only when a REGULAR payroll run that applied a repayment is
/// FINALIZED (see PayrollRunsService.buildRun) — discarding a draft run must
/// restore it. status flips to COMPLETED when balance reaches zero, or to
/// CANCELLED as a manual write-off (past repayments are not reversed).
model Loan {
  id                   String     @id @default(uuid())
  organizationId       String
  employeeId           String
  type                 LoanType
  principal            Decimal    @db.Decimal(12, 2)
  interestRate         Decimal    @default(0) @db.Decimal(5, 2) // flat %, one-time, applied to principal
  numberOfInstallments Int
  installmentAmount    Decimal    @db.Decimal(12, 2)
  balance              Decimal    @db.Decimal(12, 2) // remaining; starts at principal + interest
  status               LoanStatus @default(ACTIVE)
  disbursedDate        DateTime   @db.Date
  reason               String // required (matches PayrollAdjustment.reason)
  createdById          String
  createdAt            DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  repayments   LoanRepayment[]

  @@index([organizationId])
  @@index([employeeId, status])
  @@map("loans")
}

/// One row per installment a payroll run acted on. `amount` is what was actually
/// deducted; `deferredAmount` is how much of the scheduled installment was held
/// back to keep take-home at/above one-third of basic (Employment Act §19). A
/// fully-withheld installment is amount 0 / deferredAmount = scheduled, so the
/// deferral is auditable and visible on the payslip breakdown; the shortfall is
/// carried forward in the loan balance and picked up by a later run.
/// No organizationId — scoped via loan, same treatment as LeaveApprovalStep.
model LoanRepayment {
  id             String   @id @default(uuid())
  loanId         String
  payrollRunId   String
  payslipId      String
  amount         Decimal  @db.Decimal(12, 2)
  deferredAmount Decimal  @default(0) @db.Decimal(12, 2) // held back this run to protect the one-third floor
  balanceAfter   Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  loan       Loan       @relation(fields: [loanId], references: [id], onDelete: Restrict)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)
  payslip    Payslip    @relation(fields: [payslipId], references: [id], onDelete: Restrict)

  @@index([loanId])
  @@index([payrollRunId])
  @@map("loan_repayments")
}

/// A one-off bonus or deduction tied to a specific payroll period (not a
/// permanent SalaryComponent). PENDING adjustments are picked up by the next
/// REGULAR run covering targetPeriodMonth/Year and flip to APPLIED with the
/// run/payslip linked; discarding that draft run reverts them to PENDING.
model PayrollAdjustment {
  id                String           @id @default(uuid())
  organizationId    String
  employeeId        String
  type              AdjustmentType
  amount            Decimal          @db.Decimal(12, 2) // always positive; sign implied by `type`
  isTaxable         Boolean          @default(true) // BONUS only: whether it also folds into taxableGross
  reason            String
  targetPeriodMonth Int
  targetPeriodYear  Int
  status            AdjustmentStatus @default(PENDING)
  payrollRunId      String?
  payslipId         String?
  createdById       String
  createdAt         DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  payrollRun   PayrollRun?  @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)
  payslip      Payslip?     @relation(fields: [payslipId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([employeeId, status])
  @@index([targetPeriodYear, targetPeriodMonth])
  @@map("payroll_adjustments")
}
